# ══════════════════════════════════════════════════════════════════════════════
# Redrob AI Candidate Ranking System — API Mode Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE:
#   1. Copy this file to a new file named `.env` in the BACKEND/ directory:
#        cp .env.example .env        (Linux/macOS)
#        copy .env.example .env      (Windows)
#   2. Fill in your API keys below.
#   3. NEVER commit your real `.env` file — it is already in .gitignore.
#
# NOTE: All API keys are OPTIONAL.
#   The system runs in Competition Mode (fully local, no APIs needed) by default.
#   API Mode is an opt-in enhancement that adds LLM-powered features such as:
#     • AI reasoning summaries per candidate
#     • LLM-powered Job Description parsing
#     • Interactive candidate Q&A chat
#
# ══════════════════════════════════════════════════════════════════════════════


# ── AI Provider Selection ─────────────────────────────────────────────────────
#
# Choose which LLM provider to use when API Mode is enabled via the UI.
# Valid values: gemini | openai
#
API_MODE_PROVIDER=gemini


# ── Google Gemini (Recommended) ───────────────────────────────────────────────
#
# Get your FREE API key at: https://aistudio.google.com/app/apikey
# Required only when: API_MODE_PROVIDER=gemini
#
GEMINI_API_KEY=your_gemini_api_key_here


# ── OpenAI ────────────────────────────────────────────────────────────────────
#
# Get your API key at: https://platform.openai.com/api-keys
# Required only when: API_MODE_PROVIDER=openai
#
OPENAI_API_KEY=your_openai_api_key_here


# ── Gemini Model Selection ────────────────────────────────────────────────────
#
# GEMINI_REASONING_MODEL — Generates candidate AI reasoning/insight summaries.
#   Recommended: gemini-1.5-flash (fast & cheap) | gemini-1.5-pro (higher quality)
#
# GEMINI_JD_PARSE_MODEL — Parses uploaded Job Description files into structured data.
#   Recommended: gemini-1.5-pro (better structured JSON extraction)
#
# GEMINI_CHAT_MODEL — Powers the interactive candidate Q&A chat interface.
#   Recommended: gemini-1.5-flash (low latency for real-time chat)
#
GEMINI_REASONING_MODEL=gemini-2.0-flash
GEMINI_JD_PARSE_MODEL=gemini-2.0-flash
GEMINI_CHAT_MODEL=gemini-2.0-flash


# ── OpenAI Model Selection ────────────────────────────────────────────────────
#
# OPENAI_REASONING_MODEL — Generates candidate AI reasoning/insight summaries.
#   Recommended: gpt-4o-mini (fast & cost-efficient) | gpt-4o (highest quality)
#
# OPENAI_JD_PARSE_MODEL — Parses uploaded Job Description files into structured data.
#   Recommended: gpt-4o (best at structured JSON extraction)
#
# OPENAI_CHAT_MODEL — Powers the interactive candidate Q&A chat interface.
#   Recommended: gpt-4o-mini (low latency, lower cost)
#
OPENAI_REASONING_MODEL=gpt-4o-mini
OPENAI_JD_PARSE_MODEL=gpt-4o
OPENAI_CHAT_MODEL=gpt-4o-mini


# ── Fallback Behaviour ────────────────────────────────────────────────────────
#
# When true  → any API failure (rate limit, invalid key, network error) silently
#              falls back to the local Competition Mode pipeline.
# When false → API errors propagate as hard failures (useful for debugging).
#
# Recommendation: keep true in development, revisit in production.
#
API_FALLBACK_ENABLED=true
